+++ b/tests/gateway/test_gateway_canary_script.py
@@ -0,0 +1,178 @@
+import asyncio
+import importlib.util
+import sys
+from pathlib import Path
+
+
+def _load_script():
+    path = Path(__file__).resolve().parents[2] / "scripts" / "hermes_gateway_canary.py"
+    spec = importlib.util.spec_from_file_location("hermes_gateway_canary", path)
+    module = importlib.util.module_from_spec(spec)
+    assert spec.loader is not None
+    sys.modules[spec.name] = module
+    spec.loader.exec_module(module)
+    return module
+
+
+def test_validate_response_blocks_forbidden_phrase():
+    script = _load_script()
+    case = script.CanaryCase(
+        name="bad",
+        prompt="x",
+        required_any=("háttér",),
+        forbidden=("talál magának feladatot",),
+        max_latency_seconds=10,
+    )
+
+    result = script.validate_response(
+        case,
+        "Ez háttér, de a Pulse talál magának feladatot.",
+        1.0,
+    )
+
+    assert not result.passed
+    assert result.forbidden_found == ["talál magának feladatot"]
+
+
+def test_validate_response_fails_missing_required_any():
+    script = _load_script()
+    case = script.CanaryCase(
+        name="missing",
+        prompt="x",
+        required_any=("explicit", "rögzített"),
+    )
+
+    result = script.validate_response(case, "Nincs ilyen adat.", 1.0)
+
+    assert not result.passed
+    assert result.missing_required_any == ["explicit", "rögzített"]
+
+
+def test_run_cases_uses_dispatcher_and_collects_latency():
+    script = _load_script()
+    calls = []
+
+    async def dispatch(prompt):
+        calls.append(prompt)
+        await asyncio.sleep(0)
+        return "nem háttér explicit"
+
+    cases = [
+        script.CanaryCase(
+            name="ok",
+            prompt="prompt",
+            required_any=("explicit",),
+            required_all=("nem",),
+            forbidden=("bad",),
+            max_latency_seconds=10,
+        )
+    ]
+
+    results = asyncio.run(
+        script.run_cases(cases, dispatch, turn_timeout_seconds=5)
+    )
+
+    assert calls == ["prompt"]
+    assert len(results) == 1
+    assert results[0].passed
+    assert results[0].latency_seconds >= 0
+
+
+def test_run_cases_attaches_turn_contract_trace():
+    script = _load_script()
+
+    async def dispatch(prompt):
+        return script.DispatchOutcome(
+            response="nem háttér explicit",
+            agent_result={"tools": [], "output_tokens": 10, "model": "test-model"},
+            event_id="evt-1",
+            causal_index=7,
+            turn_profile_resolution={"turn_profile": "conversation_tools"},
+        )
+
+    def trace_factory(case, outcome, start, finished):
+        assert outcome.event_id == "evt-1"
+        return {
+            "turn_contract": {
+                "schema": "hermes.turn_contract.v1",
+                "observe_only": True,
+                "causal_index": outcome.causal_index,
+            },
+            "turn_profile_resolution": outcome.turn_profile_resolution,
+            "timing_trace": {"final_latency_ms": (finished - start) * 1000},
+            "hidden_tool_prompt_audit": {"tools_array_empty": True},
+            "observer_effect": {"extra_provider_calls": 0},
+            "idempotency": {"event_id": outcome.event_id},
+            "stale_response": {"causal_index": outcome.causal_index},
+            "provider_timing_trace": {"queue_generation_observable": False},
+            "model_contract": {"fast_model_allowed": False},
+            "degradation_decision": {"no_silent_wait_satisfied": True},
+            "readiness_report": {"chat_ready": True},
+            "aux_barrier": {"aux_blocking_ms": 0},
+        }
+
+    cases = [
+        script.CanaryCase(
+            name="ok",
+            prompt="prompt",
+            required_any=("explicit",),
+            required_all=("nem",),
+            max_latency_seconds=10,
+        )
+    ]
+
+    results = asyncio.run(
+        script.run_cases(
+            cases,
+            dispatch,
+            turn_timeout_seconds=5,
+            trace_factory=trace_factory,
+        )
+    )
+
+    assert results[0].passed
+    assert results[0].turn_contract["observe_only"] is True
+    assert results[0].turn_contract["causal_index"] == 7
+    assert results[0].turn_profile_resolution["turn_profile"] == "conversation_tools"
+    assert results[0].observer_effect["extra_provider_calls"] == 0
+    assert results[0].provider_timing_trace["queue_generation_observable"] is False
+    assert results[0].model_contract["fast_model_allowed"] is False
+    assert results[0].readiness_report["chat_ready"] is True
+
+
+def test_build_report_summarizes_failures():
+    script = _load_script()
+    args = script._parse_args(["--run-id", "unit", "--no-fail"])
+    results = [
+        script.CanaryResult("ok", "p", True, 1.5, "r"),
+        script.CanaryResult("fail", "p", False, 2.5, "r", error="x"),
+    ]
+
+    report = script._build_report(args, results)
+
+    assert report["schema"] == "hermes.gateway_canary.v2"
+    assert report["run_id"] == "unit"
+    assert report["tool_profile"] == "conversation"
+    assert not report["passed"]
+    assert report["summary"]["total"] == 2
+    assert report["summary"]["passed"] == 1
+    assert report["summary"]["failed"] == 1
+    assert report["summary"]["max_latency_seconds"] == 2.5
+    assert report["summary"]["latency"]["p95_claim_allowed"] is False
+    assert report["matrix"][0]["row_id"] == "discord:conversation:current"
+
+
+def test_parse_args_accepts_no_tools_profile():
+    script = _load_script()
+
+    args = script._parse_args(["--tool-profile", "no-tools"])
+
+    assert args.tool_profile == "no-tools"
+
+
+def test_parse_args_accepts_case_filter():
+    script = _load_script()
+
+    args = script._parse_args(["--case", "unsupported_memory_abstains"])
+
+    assert args.case == ["unsupported_memory_abstains"]
