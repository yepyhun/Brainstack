+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--snapshot", required=True)
+    parser.add_argument("--output", required=True)
+    args = parser.parse_args()
+
+    proof = build_proof(Path(args.snapshot))
