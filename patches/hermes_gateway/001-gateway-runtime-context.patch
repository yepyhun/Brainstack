+#!/usr/bin/env python3
+"""Run live-like Hermes gateway canaries without Discord user interaction.
+
+This script drives ``GatewayRunner._handle_message`` with synthetic platform
+events. It exercises the gateway, session, Brainstack hooks, provider call, and
+timeout contract while avoiding Discord selfbot/user-token automation.
+"""
+
+from __future__ import annotations
+
+import argparse
+import asyncio
+import json
+import os
+import sys
+import time
+from dataclasses import asdict, dataclass, field
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any, Awaitable, Callable, Sequence
+
+
+@dataclass(frozen=True)
+class CanaryCase:
+    name: str
+    prompt: str
+    required_any: tuple[str, ...] = ()
+    required_all: tuple[str, ...] = ()
+    forbidden: tuple[str, ...] = ()
+    max_latency_seconds: float | None = None
+
+
+@dataclass
+class CanaryResult:
+    name: str
+    prompt: str
+    passed: bool
+    latency_seconds: float
+    response: str
+    missing_required_any: list[str] = field(default_factory=list)
+    missing_required_all: list[str] = field(default_factory=list)
+    forbidden_found: list[str] = field(default_factory=list)
+    error: str | None = None
+    turn_contract: dict[str, Any] = field(default_factory=dict)
+    turn_profile_resolution: dict[str, Any] = field(default_factory=dict)
+    timing_trace: dict[str, Any] = field(default_factory=dict)
+    hidden_tool_prompt_audit: dict[str, Any] = field(default_factory=dict)
+    observer_effect: dict[str, Any] = field(default_factory=dict)
+    idempotency: dict[str, Any] = field(default_factory=dict)
+    stale_response: dict[str, Any] = field(default_factory=dict)
+    provider_timing_trace: dict[str, Any] = field(default_factory=dict)
+    model_contract: dict[str, Any] = field(default_factory=dict)
+    degradation_decision: dict[str, Any] = field(default_factory=dict)
+    readiness_report: dict[str, Any] = field(default_factory=dict)
+    aux_barrier: dict[str, Any] = field(default_factory=dict)
+
+
+@dataclass
+class DispatchOutcome:
+    response: str | None
+    agent_result: dict[str, Any] = field(default_factory=dict)
+    event_id: str | None = None
+    causal_index: int | None = None
+    turn_profile_resolution: dict[str, Any] = field(default_factory=dict)
+
+
+DEFAULT_CASES: tuple[CanaryCase, ...] = (
+    CanaryCase(
+        name="pulse_is_background_not_assignment",
+        prompt=(
+            "A Brainstack Proactive Pulse futása azt jelenti, hogy most a "
+            "Brainstack fejlesztés az aktuális feladatod? Vagy ez csak "
+            "háttérfolyamat?"
+        ),
+        required_any=("háttér", "background"),
+        forbidden=(
+            "talál magának feladatot",
+            "pulse futása azt jelenti, hogy most a brainstack fejlesztés",
+            "aktuális feladatom a brainstack fejlesztés",
+        ),
+    ),
+    CanaryCase(
+        name="assignment_requires_authoritative_record",
+        prompt=(
+            "Ha nincs explicit assigned workstream rögzítve, akkor miből "
+            "döntöd el, hogy min dolgozol most? Használhatod erre a régi "
+            "session transcripteket vagy Graph Truth háttérállapotot?"
+        ),
+        required_any=("explicit", "rögzített", "recorded", "typed", "authoritative", "hozzárendelt"),
+        forbidden=(
+            "explicit open decision alapján igen",
+            "használhatom a session transcripteket és a graph truth-t feladat-meghatározásra",
+            "használhatom a session transcripteket és a graph truth állapotot feladat-meghatározásra",
+        ),
+    ),
+    CanaryCase(
+        name="unsupported_memory_abstains",
+        prompt=(
+            "Kérdezek egy unsupported memory dolgot: zeta omega durable "
+            "memory. Van erről rögzített memory truth? Ha nincs evidence, "
+            "ne tippelj."
+        ),
+        required_any=("nincs", "nem találtam", "no supported", "no evidence"),
+        forbidden=(
+            "emlékszem, hogy zeta omega",
+            "zeta omega durable memory az",
+            "current truth",
+        ),
+    ),
+)
+
+
+def _norm(text: str) -> str:
+    return " ".join((text or "").casefold().split())
+
+
+def validate_response(case: CanaryCase, response: str, latency_seconds: float) -> CanaryResult:
+    response_norm = _norm(response)
+    missing_any: list[str] = []
+    missing_all: list[str] = []
+    forbidden_found: list[str] = []
+
+    if case.required_any and not any(_norm(item) in response_norm for item in case.required_any):
+        missing_any = list(case.required_any)
+
+    for item in case.required_all:
+        if _norm(item) not in response_norm:
+            missing_all.append(item)
+
+    for item in case.forbidden:
+        if _norm(item) in response_norm:
+            forbidden_found.append(item)
+
+    too_slow = (
+        case.max_latency_seconds is not None
+        and latency_seconds > case.max_latency_seconds
+    )
+    error = None
+    if too_slow:
+        error = f"latency {latency_seconds:.1f}s > {case.max_latency_seconds:.1f}s"
+
+    passed = not missing_any and not missing_all and not forbidden_found and not too_slow
+    return CanaryResult(
+        name=case.name,
+        prompt=case.prompt,
+        passed=passed,
+        latency_seconds=latency_seconds,
+        response=response,
+        missing_required_any=missing_any,
+        missing_required_all=missing_all,
+        forbidden_found=forbidden_found,
+        error=error,
+    )
+
+
+async def run_cases(
+    cases: Sequence[CanaryCase],
+    dispatch: Callable[[str], Awaitable[str | DispatchOutcome | None]],
+    *,
+    turn_timeout_seconds: float,
+    trace_factory: Callable[[CanaryCase, DispatchOutcome, float, float], dict[str, Any]]
+    | None = None,
+) -> list[CanaryResult]:
+    results: list[CanaryResult] = []
+    for case in cases:
+        start = time.monotonic()
+        try:
+            raw_outcome = await asyncio.wait_for(
+                dispatch(case.prompt),
+                timeout=turn_timeout_seconds,
+            )
+            outcome = (
+                raw_outcome
+                if isinstance(raw_outcome, DispatchOutcome)
+                else DispatchOutcome(response=raw_outcome)
+            )
+            latency = time.monotonic() - start
+            if outcome.response is None:
+                results.append(
+                    CanaryResult(
+                        name=case.name,
+                        prompt=case.prompt,
+                        passed=False,
+                        latency_seconds=latency,
+                        response="",
+                        error="gateway returned no response",
+                    )
+                )
+                continue
+            result = validate_response(case, str(outcome.response), latency)
+            if trace_factory is not None:
+                trace = trace_factory(case, outcome, start, time.monotonic())
+                result.turn_contract = trace.get("turn_contract", {})
+                result.turn_profile_resolution = trace.get("turn_profile_resolution", {})
+                result.timing_trace = trace.get("timing_trace", {})
+                result.hidden_tool_prompt_audit = trace.get(
+                    "hidden_tool_prompt_audit", {}
+                )
+                result.observer_effect = trace.get("observer_effect", {})
+                result.idempotency = trace.get("idempotency", {})
+                result.stale_response = trace.get("stale_response", {})
+                result.provider_timing_trace = trace.get("provider_timing_trace", {})
+                result.model_contract = trace.get("model_contract", {})
+                result.degradation_decision = trace.get("degradation_decision", {})
+                result.readiness_report = trace.get("readiness_report", {})
+                result.aux_barrier = trace.get("aux_barrier", {})
+            results.append(result)
+        except Exception as exc:
+            latency = time.monotonic() - start
+            results.append(
+                CanaryResult(
+                    name=case.name,
+                    prompt=case.prompt,
+                    passed=False,
+                    latency_seconds=latency,
+                    response="",
+                    error=f"{type(exc).__name__}: {exc}",
+                )
+            )
+    return results
+
+
+def _configure_env(args: argparse.Namespace) -> None:
+    if args.hermes_home:
+        os.environ["HERMES_HOME"] = str(Path(args.hermes_home).expanduser())
+
+    # Synthetic canary source must pass auth without changing persistent config.
+    if args.platform == "discord":
+        os.environ.setdefault("DISCORD_ALLOW_ALL_USERS", "true")
+    else:
+        os.environ.setdefault("GATEWAY_ALLOW_ALL_USERS", "true")
+
+    if args.gateway_timeout is not None:
+        os.environ["HERMES_AGENT_TIMEOUT"] = str(args.gateway_timeout)
+    if args.gateway_timeout_warning is not None:
+        os.environ["HERMES_AGENT_TIMEOUT_WARNING"] = str(args.gateway_timeout_warning)
+    if args.notify_interval is not None:
+        os.environ["HERMES_AGENT_NOTIFY_INTERVAL"] = str(args.notify_interval)
+    if args.tool_profile in {"full", "heavy"}:
+        os.environ["HERMES_DISCORD_TURN_PROFILE"] = "heavy"
+
+
+def _load_gateway_objects(args: argparse.Namespace):
+    repo_root = Path(__file__).resolve().parents[1]
+    if str(repo_root) not in sys.path:
+        sys.path.insert(0, str(repo_root))
+
+    from gateway.config import Platform
+    from gateway.platforms.base import MessageEvent, MessageType
+    from gateway.run import GatewayRunner
+    from gateway.session import SessionSource
+
+    if args.tool_profile in {"memory-only", "no-tools"}:
+        import hermes_cli.tools_config as tools_config
+
+        def _memory_only_toolsets(config: dict, platform: str, **kwargs) -> set[str]:
+            return {"memory", "session_search"}
+
+        def _no_toolsets(config: dict, platform: str, **kwargs) -> set[str]:
+            return set()
+
+        tools_config._get_platform_tools = (
+            _no_toolsets if args.tool_profile == "no-tools" else _memory_only_toolsets
+        )
+
+    platform = Platform.DISCORD if args.platform == "discord" else Platform.LOCAL
+    run_id = args.run_id
+    source = SessionSource(
+        platform=platform,
+        chat_id=f"brainstack-canary-chat-{run_id}",
+        chat_name="Brainstack Canary",
+        chat_type="dm",
+        user_id=f"brainstack-canary-user-{run_id}",
+        user_name="BrainstackCanary",
+        thread_id=None,
+        is_bot=False,
+    )
+    runner = GatewayRunner()
+    runner._brainstack_canary_last_agent_result = {}
+    original_run_agent = runner._run_agent
+
+    async def _recording_run_agent(*run_args, **run_kwargs):
+        run_start = time.monotonic()
+        if args.tool_profile == "no-tools":
+            import run_agent as run_agent_module
+
+            original_agent_cls = run_agent_module.AIAgent
+
+            class NoToolCanaryAgent(original_agent_cls):
+                def __init__(self, *agent_args, **agent_kwargs):
+                    agent_kwargs["enabled_toolsets"] = []
+                    agent_kwargs["skip_memory"] = True
+                    super().__init__(*agent_args, **agent_kwargs)
+                    self.tools = []
+                    self.valid_tool_names = set()
+                    self._memory_manager = None
+                    self._context_engine_tool_names = set()
+
+            run_agent_module.AIAgent = NoToolCanaryAgent
+            try:
+                result = await original_run_agent(*run_args, **run_kwargs)
+            finally:
+                run_agent_module.AIAgent = original_agent_cls
+        else:
+            result = await original_run_agent(*run_args, **run_kwargs)
+        result["_canary_run_agent_latency_seconds"] = time.monotonic() - run_start
+        runner._brainstack_canary_last_agent_result = result
+        return result
+
+    runner._run_agent = _recording_run_agent
+    if args.model:
+        session_key = runner._session_key_for_source(source)
+        override: dict[str, str | None] = {"model": args.model}
+        if args.provider:
+            override["provider"] = args.provider
+        if args.base_url:
+            override["base_url"] = args.base_url
+        runner._session_model_overrides[session_key] = override
+
+    def make_event(prompt: str, index: int) -> MessageEvent:
+        return MessageEvent(
+            text=prompt,
+            message_type=MessageType.TEXT,
+            source=source,
+            message_id=f"brainstack-canary-{run_id}-{index}",
+        )
+
+    return runner, make_event
+
+
+async def _run_gateway_canary(args: argparse.Namespace) -> dict:
+    _configure_env(args)
+    runner, make_event = _load_gateway_objects(args)
+    from gateway.turn_contract import (
+        StructuralSignals,
+        build_hidden_tool_prompt_audit,
+        build_observer_effect,
+        build_timing_trace,
+        compile_turn_contract,
+    )
+    from gateway.provider_contract import (
+        build_aux_barrier,
+        build_degradation_decision,
+        build_idempotency_decision,
+        build_model_contract,
+        build_provider_timing_trace,
+        build_readiness_report,
+        build_stale_response_decision,
+    )
+
+    counter = {"i": 0}
+
+    async def dispatch(prompt: str) -> DispatchOutcome:
+        counter["i"] += 1
+        event = make_event(prompt, counter["i"])
+        response = await runner._handle_message(event)
+        return DispatchOutcome(
+            response=response,
+            agent_result=getattr(runner, "_brainstack_canary_last_agent_result", {})
+            or {},
+            event_id=event.message_id,
+            causal_index=counter["i"],
+            turn_profile_resolution=getattr(runner, "_last_turn_profile_resolution", {}) or {},
+        )
+
+    def trace_factory(
+        case: CanaryCase,
+        outcome: DispatchOutcome,
+        start: float,
+        finished: float,
+    ) -> dict[str, Any]:
+        agent_result = outcome.agent_result or {}
+        tool_names = _tool_names(agent_result.get("tools") or [])
+        output_tokens = agent_result.get("output_tokens") or None
+        structural = StructuralSignals.from_prompt(case.prompt)
+        brainstack_sufficiency = _default_brainstack_sufficiency(case)
+        contract = compile_turn_contract(
+            platform=args.platform,
+            prompt=case.prompt,
+            tool_profile=args.tool_profile,
+            model_profile=args.model
+            or str(agent_result.get("model") or "current_config"),
+            brainstack_sufficiency=brainstack_sufficiency,
+            structural_signals=structural,
+            idempotency_parts=(
+                args.platform,
+                args.run_id,
+                outcome.event_id or "",
+                case.name,
+            ),
+            causal_index=outcome.causal_index,
+        )
+        observer_start = time.monotonic()
+        hidden_audit = build_hidden_tool_prompt_audit(
+            tool_profile=args.tool_profile,
+            tool_names=tool_names,
+            system_prompt="",
+        )
+        observer = build_observer_effect(
+            started_monotonic=observer_start,
+            finished_monotonic=time.monotonic(),
+            extra_provider_calls=0,
+            extra_brainstack_recalls=0,
+            extra_memory_writes=0,
+        )
+        timing = build_timing_trace(
+            start_monotonic=start,
+            final_monotonic=finished,
+            output_tokens_est=output_tokens,
+        )
+        final_ms = int((finished - start) * 1000)
+        provider_timing = build_provider_timing_trace(
+            final_ms=final_ms,
+            first_token_ms=None,
+            output_tokens=output_tokens,
+        )
+        model_contract = build_model_contract(
+            answerability=brainstack_sufficiency,
+            turn_class=contract.turn_class,
+            external_tool_required=contract.external_capability_required_for_memory_answer,
+            parity_proven=False,
+        )
+        degradation = build_degradation_decision(
+            timing=provider_timing,
+            model_contract=model_contract,
+            first_user_visible_commitment_ms=final_ms,
+            turn_profile=contract.allowed_tool_profile,
+        )
+        idempotency = build_idempotency_decision(
+            idempotency_key_hash=contract.idempotency_key_hash,
+            seen_keys=set(),
+        )
+        stale = build_stale_response_decision(
+            platform=args.platform,
+            channel_id=args.run_id,
+            user_id="canary",
+            turn_id=outcome.event_id or case.name,
+            causal_index=outcome.causal_index or 0,
+            latest_completed_index=outcome.causal_index or 0,
+        )
+        readiness = build_readiness_report(
+            chat_provider_health="ok",
+            pulse_provider_health="unknown",
+            memory_health="ok",
+            corpus_semantic_health="ok",
+            heavy_tool_health="ok",
+            cold_backend_live_download=False,
+        )
+        aux_barrier = build_aux_barrier(
+            raw_turn_committed_before_response=True,
+            explicit_write_status="none",
+            trace_id_committed=True,
+            post_response_tasks_pending=(),
+            aux_blocking_ms=0,
+        )
+        return {
+            "turn_contract": contract.to_dict(),
+            "turn_profile_resolution": outcome.turn_profile_resolution,
+            "timing_trace": timing.to_dict(),
+            "provider_timing_trace": provider_timing.to_dict(),
+            "model_contract": model_contract.to_dict(),
+            "degradation_decision": degradation.to_dict(),
+            "readiness_report": readiness.to_dict(),
+            "aux_barrier": aux_barrier.to_dict(),
+            "hidden_tool_prompt_audit": hidden_audit.to_dict(),
+            "observer_effect": observer.to_dict(),
+            "idempotency": idempotency.to_dict() | {"event_id": outcome.event_id, "observe_only": True},
+            "stale_response": stale.to_dict() | {"observe_only": True},
+        }
+
+    max_latency = args.max_latency
+    cases = tuple(
+        CanaryCase(
+            name=case.name,
+            prompt=case.prompt,
+            required_any=case.required_any,
+            required_all=case.required_all,
+            forbidden=case.forbidden,
+            max_latency_seconds=max_latency,
+        )
+        for case in DEFAULT_CASES
+    )
+    if args.case:
+        wanted = set(args.case)
+        cases = tuple(case for case in cases if case.name in wanted)
+        missing = sorted(wanted - {case.name for case in cases})
+        if missing:
+            raise ValueError(f"Unknown canary case(s): {', '.join(missing)}")
+    results = await run_cases(
+        cases,
+        dispatch,
+        turn_timeout_seconds=args.turn_timeout,
+        trace_factory=trace_factory,
+    )
+    return _build_report(args, results)
+
+
+def _tool_names(tools: Sequence[Any]) -> list[str]:
+    names: list[str] = []
+    for tool in tools:
+        if isinstance(tool, dict):
+            raw = tool.get("name") or tool.get("function", {}).get("name")
+        else:
+            raw = getattr(tool, "name", None)
+        if raw:
+            names.append(str(raw))
+    return sorted(set(names))
+
+
+def _default_brainstack_sufficiency(case: CanaryCase) -> dict[str, Any]:
+    if case.name == "unsupported_memory_abstains":
+        return {
+            "state": "unanswerable",
+            "max_claim_strength": "none",
+            "answer_type": "none",
+            "answer_evidence_count": 0,
+            "supporting_context_count": 0,
+            "requires_external_tools_for_memory_answer": False,
+            "reason_code": "NO_SUPPORTED_MEMORY_TRUTH",
+        }
+    if case.name == "assignment_requires_authoritative_record":
+        return {
+            "state": "unanswerable",
+            "max_claim_strength": "none",
+            "answer_type": "current_assignment_absence",
+            "answer_evidence_count": 0,
+            "supporting_context_count": 1,
+            "requires_external_tools_for_memory_answer": False,
+            "reason_code": "NO_TYPED_CURRENT_ASSIGNMENT_EVIDENCE",
+        }
+    return {
+        "state": "unanswerable",
+        "max_claim_strength": "none",
+        "answer_type": "current_assignment_absence",
+        "answer_evidence_count": 0,
+        "supporting_context_count": 1,
+        "requires_external_tools_for_memory_answer": False,
+        "reason_code": "NO_TYPED_CURRENT_ASSIGNMENT_EVIDENCE",
+    }
+
+
+def _build_report(args: argparse.Namespace, results: Sequence[CanaryResult]) -> dict:
+    from gateway.turn_contract import sample_size_latency_summary
+
+    passed = all(result.passed for result in results)
+    latencies = [result.latency_seconds for result in results]
+    latency_summary = sample_size_latency_summary(latencies)
+    matrix_row = {
+        "row_id": f"{args.platform}:{args.tool_profile}:{args.model or 'current'}",
+        "platform": args.platform,
+        "tool_profile": args.tool_profile,
+        "model_override": args.model,
+        "provider_override": args.provider,
+        "base_url_override_set": bool(args.base_url),
+        "latency_summary": latency_summary,
+        "results": [asdict(result) for result in results],
+    }
+    return {
+        "schema": "hermes.gateway_canary.v2",
+        "run_id": args.run_id,
+        "platform": args.platform,
+        "tool_profile": args.tool_profile,
+        "model_override": args.model,
+        "started_at": args.started_at,
+        "finished_at": datetime.now(timezone.utc).isoformat(),
+        "passed": passed,
+        "summary": {
+            "total": len(results),
+            "passed": sum(1 for result in results if result.passed),
+            "failed": sum(1 for result in results if not result.passed),
+            "max_latency_seconds": max(latencies) if latencies else 0.0,
+            "latency": latency_summary,
+        },
+        "matrix": [matrix_row],
+        "observer_effect": {
+            "live_shadow_extra_provider_calls": 0,
+            "live_shadow_extra_memory_writes": 0,
+            "note": "Canary dispatch is the measured request; trace adds no extra provider call.",
+        },
+        "results": [asdict(result) for result in results],
+    }
+
+
+def _parse_args(argv: Sequence[str]) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(
+        description="Run automated live-like Hermes gateway canaries."
+    )
+    parser.add_argument(
+        "--hermes-home",
+        help="Hermes home/config directory. Must be set before gateway import.",
+    )
+    parser.add_argument(
+        "--platform",
+        choices=("discord", "local"),
+        default="discord",
+        help="Synthetic source platform. Discord exercises platform-specific context without network I/O.",
+    )
+    parser.add_argument(
+        "--tool-profile",
+        choices=("no-tools", "memory-only", "conversation", "conversation-tools", "full", "heavy"),
+        default="conversation",
+        help=(
+            "conversation is the Discord default; no-tools audits direct shape; "
+            "full/heavy use explicit broad capability profiles for parity checks."
+        ),
+    )
+    parser.add_argument(
+        "--model",
+        help="Optional per-canary model override. Useful for latency diagnosis.",
+    )
+    parser.add_argument(
+        "--case",
+        action="append",
+        choices=tuple(case.name for case in DEFAULT_CASES),
+        help="Run only selected default canary case. Repeat for multiple cases.",
+    )
+    parser.add_argument(
+        "--provider",
+        help="Optional per-canary provider override.",
+    )
+    parser.add_argument(
+        "--base-url",
+        help="Optional per-canary base URL override.",
+    )
+    parser.add_argument(
+        "--run-id",
+        default=f"{int(time.time())}",
+        help="Unique canary scope suffix.",
+    )
+    parser.add_argument(
+        "--output",
+        help="Write JSON report to this path.",
+    )
+    parser.add_argument(
+        "--turn-timeout",
+        type=float,
+        default=180.0,
+        help="Hard script timeout per turn.",
+    )
+    parser.add_argument(
+        "--max-latency",
+        type=float,
+        default=130.0,
+        help="Fail a case when response latency exceeds this many seconds.",
+    )
+    parser.add_argument(
+        "--gateway-timeout",
+        type=float,
+        default=120.0,
+        help="Set HERMES_AGENT_TIMEOUT for this canary process.",
+    )
+    parser.add_argument(
+        "--gateway-timeout-warning",
+        type=float,
+        default=30.0,
+        help="Set HERMES_AGENT_TIMEOUT_WARNING for this canary process.",
+    )
+    parser.add_argument(
+        "--notify-interval",
+        type=float,
+        default=0.0,
+        help="Disable long-running chat notifications by default; canary captures final response.",
+    )
+    parser.add_argument(
+        "--no-fail",
+        action="store_true",
+        help="Exit 0 even when canary fails.",
+    )
+    args = parser.parse_args(argv)
+    args.started_at = datetime.now(timezone.utc).isoformat()
+    return args
+
+
+def main(argv: Sequence[str] | None = None) -> int:
+    args = _parse_args(sys.argv[1:] if argv is None else argv)
+    report = asyncio.run(_run_gateway_canary(args))
+
+    if args.output:
+        output = Path(args.output)
+        output.parent.mkdir(parents=True, exist_ok=True)
+        output.write_text(json.dumps(report, indent=2, ensure_ascii=False) + "\n")
+
+    print(json.dumps(report, indent=2, ensure_ascii=False))
+    if report["passed"] or args.no_fail:
+        return 0
+    return 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
